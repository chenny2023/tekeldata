# ─────────────────────────────────────────────────────────────────────────────
# WCOIN.CASINO — all values are OPTIONAL. With an empty .env the platform still
# collects REAL data via keyless public endpoints:
#   • ETH + TRON transfer indexing (public RPC / TronGrid)
#   • Casino-wallet attribution (Etherscan gambling labels + Tronscan tags)
#   • Kick streamer monitoring (public channel API)
# Add keys below for higher rate limits and the optional modules.
# ─────────────────────────────────────────────────────────────────────────────

PORT=8787
NODE_ENV=development
DB_PATH=server/data/wcoin.db

# ── Ethereum ─────────────────────────────────────────────────────────────────
# Your own RPC (Alchemy/Infura/QuickNode) — recommended for production.
# EVM_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Tron ─────────────────────────────────────────────────────────────────────
# Preferred collector: EVM-compat JSON-RPC (eth_getLogs wide scans + backfill).
# Default is TronGrid's public /jsonrpc (keyless, rate-limited). For unlimited
# rate paste a dedicated TRON endpoint created with protocol = JSON-RPC
# (e.g. GetBlock — NOTE: their gRPC-protocol endpoints will NOT work here).
# TRON_JSONRPC=https://go.getblock.io/YOUR_JSONRPC_TOKEN
# TRON_MODE=jsonrpc            # jsonrpc (default) | v1 (TronGrid REST poller)
# TRON_MAX_RANGE=4500          # blocks per getLogs (node cap is 5000)
# TronGrid REST key — only used in v1 mode and for the label harvester.
# TRONGRID_KEY=your_trongrid_key

# ── Indexer tuning (defaults shown) ──────────────────────────────────────────
# EVM_BACKFILL_BLOCKS=120
# EVM_POLL_MS=12000
# DEEP_BACKFILL_DAYS=14        # ETH history walked backward on boot (0 = off)
# DEEP_BACKFILL_RANGE=1500     # starting getLogs range (adaptive)
# TRON_BACKFILL_HOURS=72
# TRON_POLL_MS=6000
# TRON_PAGES_PER_TICK=5
# WHALE_USD=100000

# ── Optional: Twitch streamer monitoring (Helix API) ─────────────────────────
# Create an app at https://dev.twitch.tv/console/apps
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=

# ── Optional: Reddit social mentions / sentiment ─────────────────────────────
# Create a free "script" app at https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# ─── Automated X content pipeline (OpenRouter Grok → QA → publish) ─────────────
# OFF by default. Fill these, set CONTENT_ENABLED=1, redeploy. Preview first via
# GET /api/content/preview?type=daily_market_thread (logged-in) — it generates +
# QA-checks WITHOUT posting until the X keys below are present.
CONTENT_ENABLED=0

# OpenRouter (LLM). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEXT_MODEL=x-ai/grok-4
OPENROUTER_TEXT_MODEL_FALLBACK=x-ai/grok-4-fast
OPENROUTER_IMAGE_MODEL=x-ai/grok-imagine-image-quality
OPENROUTER_APP_NAME=WCOIN.CASINO
OPENROUTER_SITE_URL=https://wcoin.casino

# X (Twitter) — OAuth 1.0a user context (needed to POST). Create an app at
# https://developer.x.com → Keys & tokens. The access token/secret must be for an
# app with Read+Write permission.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_ACCOUNT_ID=

# Optional: post times (UTC hour)
CONTENT_THREAD_HOUR_UTC=13
CONTENT_RANKING_HOUR_UTC=16
CONTENT_SIGNAL_HOUR_UTC=20
